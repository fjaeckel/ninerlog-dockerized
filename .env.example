# =============================================================================
# NinerLog — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values.
#
# Required variables are marked with [REQUIRED].
# All others have sensible defaults.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_DB=ninerlog
POSTGRES_USER=ninerlog
POSTGRES_PASSWORD=                # [REQUIRED] Choose a strong password

# -----------------------------------------------------------------------------
# Authentication — CHANGE THESE
# -----------------------------------------------------------------------------
JWT_SECRET=                       # [REQUIRED] Min 32 chars, random string
REFRESH_SECRET=                   # [REQUIRED] Min 32 chars, different from JWT_SECRET
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost      # Change to https://yourdomain.com in production

# -----------------------------------------------------------------------------
# WebAuthn / Passkeys  (optional — disabled if WEBAUTHN_RP_ID is empty)
# -----------------------------------------------------------------------------
# Passkeys require a SECURE CONTEXT in the browser (HTTPS, or http://localhost).
# RP_ID must be a registrable domain (e.g. "logbook.example.com" or "example.com")
# — single-label hostnames like "localhost-dev" are rejected by the WebAuthn spec.
# RP_ID must match the host the user visits in the browser (or be a parent of it).
# RP_ORIGINS is a comma-separated list of full origins (scheme + host + port).
# See docs/PASSKEYS.md for details.
#
# WEBAUTHN_RP_ID=logbook.example.com
# WEBAUTHN_RP_NAME=NinerLog
# WEBAUTHN_RP_ORIGINS=https://logbook.example.com

# -----------------------------------------------------------------------------
# TLS / HTTPS  (leave empty for HTTP-only / local testing)
# -----------------------------------------------------------------------------
# TLS_DOMAIN=logbook.example.com

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
GIN_MODE=release                  # debug | release | test
LOG_LEVEL=info                    # debug | info | warn | error
FRONTEND_PORT=80
FRONTEND_TLS_PORT=443

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api/v1
VITE_ENV=production
# APP_NAME=NinerLog
# BETA_PASSWORD=                  # Set to require a password for registration

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# SMTP / Email  (optional — emails are logged to stdout when SMTP_HOST is empty)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@ninerlog.app

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# NOTIFICATION_CHECK_INTERVAL=1h

# -----------------------------------------------------------------------------
# GitHub Container Registry  (temporary — until images are public)
# -----------------------------------------------------------------------------
# GITHUB_USER=your-github-username
# GITHUB_TOKEN=ghp_...          # Personal access token with read:packages scope
